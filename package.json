{
  "name": "alpha",
  "version": "1.0.0",
  "main": "expo-router/entry",
  "scripts": {
    "start": "EXPO_NO_DEVTOOLS=1 expo start --web --port 3000",
    "dev": "EXPO_NO_DEVTOOLS=1 expo start --web --port 3000",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "build": "echo 'Android project. Skipping web export.'",
    "lint": "expo lint",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "test": "jest",
    "test:coverage": "jest --coverage",
    "test:db": "jest db.test.ts",
    "test:integration": "jest integration.test.ts",
    "test:e2e": "maestro test .maestro",
    "verify": "pnpm run typecheck && pnpm run test",
    "prebuild": "expo prebuild",
    "build:android:debug": "cd android && ./gradlew assembleDebug",
    "build:android:release": "cd android && ./gradlew assembleRelease",
    "build:android:aab": "cd android && ./gradlew bundleRelease",
    "build:android:all": "pnpm run build:android:debug && pnpm run build:android:release && pnpm run build:android:aab"
  },
  "dependencies": {
    "@expo/metro-runtime": "^56.0.15",
    "@supabase/supabase-js": "^2.47.0",
    "date-fns": "^4.1.0",
    "expo": "~56.0.0",
    "expo-asset": "~56.0.0",
    "expo-blur": "~56.0.0",
    "expo-constants": "~56.0.0",
    "expo-crypto": "^56.0.4",
    "expo-linear-gradient": "~56.0.4",
    "expo-local-authentication": "~56.0.0",
    "expo-router": "~56.2.11",
    "expo-secure-store": "~56.0.0",
    "expo-sqlite": "~56.0.0",
    "expo-status-bar": "~56.0.0",
    "expo-system-ui": "~56.0.0",
    "lucide-react-native": "^0.469.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.85.3",
    "react-native-gesture-handler": "~2.31.2",
    "react-native-reanimated": "~4.3.1",
    "react-native-safe-area-context": "5.7.0",
    "react-native-screens": "~4.25.2",
    "react-native-svg": "^15.15.4",
    "react-native-url-polyfill": "^3.0.0",
    "react-native-web": "^0.21.2",
    "zod": "^3.24.0",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@babel/core": "^7.20.0",
    "@react-native/jest-preset": "^0.86.0",
    "@types/jest": "^30.0.0",
    "@types/react": "~19.2.17",
    "eslint": "^9.39.4",
    "eslint-config-expo": "~56.0.4",
    "jest": "^29.0.0",
    "jest-expo": "^56.0.5",
    "prettier": "^3.0.0",
    "typescript": "^6.0.3"
  },
  "private": true
}
